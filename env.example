# Fichier d'exemple pour les variables d'environnement
# Copier ce fichier en .env et remplir avec vos vraies valeurs

# ===== DJANGO CORE =====
# IMPORTANT: Générer une clé sécurisée avec:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=votre-secret-key-a-generer-avec-django

# Mode debug (TOUJOURS False en production)
DEBUG=False

# Hôtes autorisés (séparés par des virgules, OBLIGATOIRE en production)
ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.com

# ===== BASE DE DONNÉES =====
DB_NAME=ggr_credit_workflow
DB_USER=postgres
DB_PASSWORD=votre-mot-de-passe-db
DB_HOST=localhost
DB_PORT=5434

# Alternative: URL complète de la base de données
# DATABASE_URL=postgresql://user:password@localhost:5434/ggr_credit_workflow

# ===== REDIS (Cache et Sessions) =====
REDIS_URL=redis://127.0.0.1:6379/1

# ===== EMAIL (optionnel) =====
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-email
DEFAULT_FROM_EMAIL=no-reply@ggr-credit.cg

# ===== SÉCURITÉ (Production) =====
# CSRF Trusted Origins (séparés par des virgules)
CSRF_TRUSTED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# ===== MONITORING (optionnel) =====
# SENTRY_DSN=https://votre-cle@sentry.io/votre-projet

# ===== ENVIRONNEMENT =====
ENVIRONMENT=production
